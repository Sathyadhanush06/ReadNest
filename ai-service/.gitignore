ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually personal.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, they may break the lock.
#   So you can choose to ignore or commit.
# Pipfile.lock

# poetry
#   Similar to Pipenv, generally respect poetry.lock over ignoring it
# poetry.lock

# pdm
#   Similar to Pipenv, generally respect pdm.lock over ignoring it
# pdm.lock

# virtualenv
#   Virtual environments should never be committed to git!
venv/
.venv/
ENV/
env/
active_env/
active_env.py/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

